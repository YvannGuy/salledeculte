{"name":"salleculte","version":"0.1.0","private":true,"scripts":{"dev":"next dev","build":"next build","start":"next start","lint":"next lint","update-communes":"curl -s 'https://geo.api.gouv.fr/communes?codeRegion=11&fields=nom&format=json' | node -e \"const c=[];process.stdin.on('data',d=>c.push(d));process.stdin.on('end',()=>{const n=JSON.parse(Buffer.concat(c).toString()).map(x=>x.nom).sort((a,b)=>a.localeCompare(b,'fr'));require('fs').writeFileSync('lib/data/communes-idf.json',JSON.stringify(n));console.log(n.length+' communes')});\"","supabase:init-storage":"node scripts/init-storage.mjs","supabase:init-message-storage":"node scripts/init-message-storage.mjs","supabase:init-contract-storage":"node scripts/init-contract-storage.mjs","supabase:init-edl-storage":"node scripts/init-edl-storage.mjs"},"dependencies":{"@floating-ui/dom":"^1.7.5","@hookform/resolvers":"^5.2.2","@radix-ui/react-accordion":"^1.2.12","@radix-ui/react-dialog":"^1.1.15","@radix-ui/react-popover":"^1.1.15","@radix-ui/react-select":"^2.2.6","@radix-ui/react-slot":"^1.2.4","@sentry/nextjs":"^10.40.0","@stripe/stripe-js":"^8.7.0","@supabase/ssr":"^0.8.0","@supabase/supabase-js":"^2.97.0","@types/leaflet":"^1.9.21","class-variance-authority":"^0.7.1","clsx":"^2.1.1","date-fns":"^4.1.0","dotenv":"^17.3.1","leaflet":"^1.9.4","lucide-react":"^0.575.0","next":"^16.1.6","pdf-lib":"^1.17.1","react":"^19.2.4","react-day-picker":"^9.13.2","react-dom":"^19.2.4","react-hook-form":"^7.71.1","react-leaflet":"^5.0.0","react-leaflet-cluster":"^4.0.0","react-markdown":"^10.1.0","resend":"^6.9.2","sharp":"^0.34.5","stripe":"^20.3.1","tailwind-merge":"^3.5.0","zod":"^4.3.6"},"devDependencies":{"@types/node":"^20","@types/react":"^19.2.14","@types/react-dom":"^19.2.3","eslint":"^9.39.2","eslint-config-next":"^16.1.6","postcss":"^8","tailwindcss":"^3.4.1","typescript":"^5"}}